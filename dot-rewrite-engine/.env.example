SUPABASE_DB_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres
ENGINE_LOG_LEVEL=INFO

# Optional: enable Claude-powered concrete topic labels.
# Without this set, the engine keeps algorithmic keyword labels.
# ANTHROPIC_API_KEY=sk-ant-...

# Pick the LLM backend. Defaults to "anthropic". Set to "ollama" to run
# everything against a local Ollama daemon with zero cloud calls.
# ENGINE_LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b-instruct
# Optional per-task override: OLLAMA_LABELER_MODEL=qwen2.5:3b-instruct
